<%- include('partials/header') %>
<div class="page-header"><h1>⚙️ Settings</h1></div>
<section class="section">
  <h2>Change Password</h2>
  <form method="POST" action="/settings/password" class="settings-form">
    <div class="form-group">
      <label>Current Password</label>
      <input type="password" name="current_pass" required />
    </div>
    <div class="form-group">
      <label>New Password</label>
      <input type="password" name="new_pass" required minlength="6" />
    </div>
    <button type="submit" class="btn-primary">Update Password</button>
  </form>
</section>
<section class="section">
  <h2>Theme</h2>
  <button onclick="setTheme('light')" class="btn-secondary">☀️ Light</button>
  <button onclick="setTheme('dark')" class="btn-secondary">🌙 Dark</button>
</section>
<script>
async function setTheme(t) {
  await fetch('/settings/theme', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({theme:t}) });
  document.documentElement.setAttribute('data-theme', t);
}
</script>
<%- include('partials/footer') %>
